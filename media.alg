Algoritmo "media"

Var
	valor1,valor2,valor3,valor4,media:real

Inicio
escreval("Calculadora de média")
escreval("Insira valor 1: ")
leia(valor1)
escreval("Insira valor 2: ")
leia(valor2)
escreval("Insira valor 3: ")
leia(valor3)
escreval("Insira valor 4: ")
leia(valor4)

media<-(valor1+valor2+valor3+valor4)/4

escreval("A média: ",media)

fimalgoritmo