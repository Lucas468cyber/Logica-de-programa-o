Algoritmo "multiplicacao_por_dois"

Var
	cont:inteiro
  resp:inteiro
  i,j:inteiro
Inicio
	para i de 1 ate 10 passo 1 faca
  	escreval("Tabuada do ", i)
    escreval("")
    para j de 0 ate 10 passo 1 faca
    	resp<- i * j
      escreval(i," X ", j ," = ", resp)  	
    fimpara
  fimpara



fimalgoritmo