Algoritmo "estruturaDecisao"

Var
	valor1, valor2:inteiro

Inicio
	escreval("Insira o primeiro valor")
  leia(valor1)
  escreval("Insira o segundo valor")
  leia(valor2)
  
  se valor1 = valor2 entao
  	escreval("Os dois valores são iguais")
  fimse
  se valor1 <> valor2 entao
  	escreval("Os dois valores são diferentes")
  fimse
fimalgoritmo